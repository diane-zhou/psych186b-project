    "# Takes a movie name, year and returns the Letterboxd reviews URL\n",
    "def get_letterboxd_url(driver, movie_name, year=None):\n",
    "    slug = movie_name.lower().replace(\" \", \"-\")\n",
    "    \n",
    "    # Try direct URL first (most movies follow this pattern)\n",
    "    if year:\n",
    "        url = f\"https://letterboxd.com/film/{slug}-{year}/reviews/by/activity/\"\n",
    "    else:\n",
    "        url = f\"https://letterboxd.com/film/{slug}/reviews/by/activity/\"\n",
    "    \n",
    "    driver.get(url)\n",
    "    time.sleep(4)\n",
    "    \n",
    "    # Check if page loaded correctly (not a 404)\n",
    "    if \"Page Not Found\" in driver.title or \"Letterboxd • Error\" in driver.title:\n",
    "        raise ValueError(f\"Could not find Letterboxd page for: {movie_name}. Try passing year= or check the slug manually at letterboxd.com/film/{slug}/\")\n",
    "    \n",
    "    print(f\"Found: {driver.title} → {url}\")\n",
    "    return url\n",
    "\n",
    "# Scrapes top 50 audience reviews from Letterboxd\n",
    "def scrape_letterboxd_reviews(driver, reviews_url, movie_name):\n",
    "    print(\"Scraping Letterboxd reviews...\")\n",
    "    driver.get(reviews_url)\n",
    "    time.sleep(5)\n",
    "\n",
    "    reviews = []\n",
    "    count = 0\n",
    "    processed = 0\n",
    "\n",
    "    while len(reviews) < 50:\n",
    "        soup = BeautifulSoup(driver.page_source, \"html.parser\")\n",
    "        review_cards = soup.find_all(\"div\", class_=\"listitem\")\n",
    "\n",
    "        print(f\"Found {len(review_cards)} review cards, processing new batch...\")\n",
    "\n",
    "        for i, card in enumerate(review_cards):\n",
    "            if len(reviews) >= 50:\n",
    "                break\n",
    "            if i < processed:\n",
    "                continue\n",
    "\n",
    "            review = {}\n",
    "            count += 1\n",
    "            review[\"id\"] = count\n",
    "\n",
    "            # Reviewer name\n",
    "            name_tag = card.find(\"strong\", class_=\"displayname\")\n",
    "            review[\"reviewer_name\"] = name_tag.get_text(strip=True) if name_tag else \"N/A\"\n",
    "\n",
    "            # Reviewer username (from href e.g. /username/)\n",
    "            username_tag = card.find(\"a\", class_=\"avatar\")\n",
    "            review[\"reviewer_username\"] = username_tag[\"href\"].strip(\"/\").split(\"/\") if username_tag else \"N/A\"\n",
    "\n",
    "            # Date\n",
    "            date_tag = card.find(\"time\", class_=\"timestamp\")\n",
    "            review[\"date\"] = date_tag.get_text(strip=True) if date_tag else \"N/A\"\n",
    "\n",
    "            # Star rating (stored as class e.g. \"rated-7\" = 3.5 stars)\n",
    "            rating_tag = card.find(\"span\", class_=lambda c: c and \"rated-\" in c)\n",
    "            if rating_tag:\n",
    "                rated_class = [c for c in rating_tag[\"class\"] if \"rated-\" in c][0]\n",
    "                raw_rating = int(rated_class.split(\"-\")[1])\n",
    "                review[\"rating\"] = raw_rating / 2  # Convert to 5-star scale\n",
    "            else:\n",
    "                review[\"rating\"] = \"N/A\"\n",
    "\n",
    "            # Review text\n",
    "            text_tag = card.find(\"div\", class_=\"collapsed-text\")\n",
    "            if text_tag:\n",
    "                # Remove the \"more\" link\n",
    "                more_link = text_tag.find(\"a\", class_=\"reveal\")\n",
    "                if more_link:\n",
    "                    more_link.decompose()\n",
    "                review[\"review_text\"] = text_tag.get_text(strip=True)\n",
    "            else:\n",
    "                review[\"review_text\"] = \"N/A\"\n",
    "\n",
    "            reviews.append(review)\n",
    "\n",
    "        processed = len(review_cards)\n",
    "\n",
    "        if len(reviews) < 50:\n",
    "            # Go to next page\n",
    "            next_btn = soup.find(\"a\", class_=\"next\")\n",
    "            if next_btn:\n",
    "                next_url = \"https://letterboxd.com\" + next_btn[\"href\"]\n",
    "                print(f\"Loading next page...\")\n",
    "                driver.get(next_url)\n",
    "                time.sleep(3)\n",
    "            else:\n",
    "                print(\"No more pages.\")\n",
    "                break\n",
    "\n",
    "    reviews = reviews[:50]\n",
    "    df = pd.DataFrame(reviews, columns=[\"id\", \"reviewer_name\", \"reviewer_username\", \"date\", \"rating\", \"review_text\"])\n",
    "    filename = f\"{movie_name.replace(' ', '_')}_letterboxd_reviews.csv\"\n",
    "    df.to_csv(filename, index=False)\n",
    "    print(f\"Saved {len(df)} reviews to {filename}\")\n",
    "    return df"
   ]
